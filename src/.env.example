# Django Settings
DEBUG=False
SECRET_KEY=secret-key-here
ALLOWED_HOSTS=domain.com
CSRF_TRUSTED_ORIGINS=https://domain.com

# Database Configuration
DB_ENGINE=django.db.backends.mysql
DB_NAME=database_name
DB_USER=database_user
DB_PASSWORD=database_password
DB_HOST=localhost
DB_PORT=3306

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.mail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=email@mail.com
EMAIL_HOST_PASSWORD=app-specific-password
DEFAULT_FROM_EMAIL= Name <email@mail.com>

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME=24  # hours
JWT_REFRESH_TOKEN_LIFETIME=7  # days
JWT_SIGNING_KEY=${SECRET_KEY}

# CORS Settings
CORS_ALLOWED_ORIGINS=https://domain.com

# Media and Static Files
MEDIA_URL=/media/
STATIC_URL=/static/

# GPT-5 mini feature flag (defaults enable for all clients)
GPT5_MINI_ENABLED=True
# Choose 'all_clients' or 'whitelist'
GPT5_MINI_MODE=all_clients
# Comma-separated client IDs when using whitelist mode, e.g. client1,client2
GPT5_MINI_WHITELIST=
# MWECAU DigiVote - Environment Variables Template
# Copy this file to .env.development or .env.production and fill in your values
# NEVER commit actual secrets to version control!

# Django Core Settings
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
DB_ENGINE=django.db.backends.sqlite3
# For PostgreSQL:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=your_db_name
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yoursite.com

# Site Configuration
SITE_URL=http://localhost:5000

# Security Settings (Production Only)
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
SITE_NAME=MWECAU DigiVote

# Celery Configuration (Redis-backed for production)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_ALWAYS_EAGER=False

# JWT Token Configuration
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=86400
JWT_ALGORITHM=HS256

# CSRF & Security
CSRF_TRUSTED_ORIGINS=http://localhost:5000

# API Configuration
API_TIMEOUT=30
API_RATE_LIMIT=1000/hour

# Logging Configuration
LOG_LEVEL=DEBUG
LOG_FILE=src/logs/debug.log

# Redis Configuration (required for caching and Celery)
REDIS_URL=redis://localhost:6379/1

# External Services
SMS_PROVIDER=console
SMS_API_KEY=your-sms-api-key
SMS_API_SECRET=your-sms-api-secret

# Feature Flags
ENABLE_EMAIL_NOTIFICATIONS=True
ENABLE_SMS_NOTIFICATIONS=False
ENABLE_API_THROTTLING=False
ENABLE_DEBUG_TOOLBAR=True

# Security Settings
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
CSRF_COOKIE_HTTPONLY=True

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Media Files
MEDIA_ROOT=src/media
MEDIA_URL=/media/

# Static Files
STATIC_ROOT=src/staticfiles
STATIC_URL=/static/

# Application Version
APP_VERSION=1.0.0
ENVIRONMENT=development
